# Copy this file to .local_data/config.env and fill in real values.
# .local_data/ is gitignored - never commit real credentials.

INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=replace-with-real-token
INFLUX_ORG=replace-with-real-org

BIND_HOST=0.0.0.0
BIND_PORT=8085
LOG_LEVEL=info

# Operating mode. "iobroker" (default) enables full ioBroker support: auto-detects
# tag-based vs field-based storage per measurement, groups field-based data into one
# row per logical point, and handles Add/Edit/Delete/Retime/ODS correctly for both.
# Set to "default" to disable ioBroker-specific behaviour.
INFLUXWEB_MODE=iobroker
