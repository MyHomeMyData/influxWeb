[Unit]
Description=influxWeb - Admin UI for local InfluxDB
After=network.target influxdb.service

[Service]
Type=simple
User=influxweb
Group=influxweb
WorkingDirectory=/opt/influxweb
EnvironmentFile=/opt/influxweb/.local_data/config.env
ExecStart=/opt/influxweb/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8085
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
